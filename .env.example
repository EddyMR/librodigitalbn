# Supabase — copia estos valores desde tu proyecto en supabase.com
# Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# URL pública de tu app (sin slash final)
# En Vercel lo obtienes después del primer deploy
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# Contraseña para el panel de administrador global (/admin)
# Usa algo largo y seguro — solo tú lo sabrás
ADMIN_GENERAL_SECRET=pon-aqui-una-contrasena-segura
